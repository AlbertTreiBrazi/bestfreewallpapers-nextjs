# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# Supabase — required
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CDN and site URL — optional, defaults shown
NEXT_PUBLIC_CDN_URL=https://cdn.bestfreewallpapers.com
NEXT_PUBLIC_SITE_URL=https://bestfreewallpapers.com

# Admin API protection — optional but recommended
ADMIN_SECRET=your-random-secret-for-extract-colors-api
